# ==========================================
# 官方直连 API 配置模板
# 适用于分别使用 OpenAI 官方 API 与 Anthropic 官方 API
# ==========================================

# --- GPT / OpenAI 官方直连 ---
OPENAI_API_KEY=your_official_openai_api_key_here
OPENAI_API_BASE=
MODEL_ANALYSIS=gpt-5.5
MODEL_CODER_API=gpt-5.4-mini
MODEL_MANAGER_SUMMARY=gpt-5.4-mini
CODER_EXECUTION_MODE=API

# --- Claude / Anthropic 官方直连 ---
ANTHROPIC_API_KEY=your_official_anthropic_api_key_here
ANTHROPIC_BASE_URL=
MODEL_DATA_PROCESS=claude-opus-4-6
